---
const { formId } = Astro.props;
const buttonText = formId === 'footerForm' ? 'Subscribe' : 'Join the movement';
---

<div class="signup-container">
    <form class="signup-form" id={formId}>
        <input type="email" name="email" placeholder="Enter your email" required>
        <button type="submit">{buttonText}</button>
    </form>
</div>

<script>
        const WORKER_URL = 'https://progressives-signup.restless-salad-a31e.workers.dev';

        async function handleSubmit(form, buttonText) {
            const email = form.email.value;
            const button = form.querySelector('button');
            const container = form.parentElement;

            button.disabled = true;
            button.textContent = 'Joining...';

            try {
                const response = await fetch(WORKER_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });

                const result = await response.json();

                if (response.ok) {
                    container.innerHTML = '<div class="signup-message success">Welcome aboard! Check your inbox.</div>';
                } else {
                    throw new Error(result.error || 'Something went wrong');
                }
            } catch (error) {
                // Build nodes via the DOM (never interpolate user input into innerHTML)
                const msg = document.createElement('div');
                msg.className = 'signup-message error';
                msg.textContent = error.message;
                container.replaceChildren(msg);
                setTimeout(() => {
                    const newForm = document.createElement('form');
                    newForm.className = 'signup-form';
                    newForm.id = form.id;
                    const input = document.createElement('input');
                    input.type = 'email';
                    input.name = 'email';
                    input.placeholder = 'Enter your email';
                    input.required = true;
                    input.value = email;
                    const btn = document.createElement('button');
                    btn.type = 'submit';
                    btn.textContent = buttonText;
                    newForm.append(input, btn);
                    container.replaceChildren(newForm);
                    attachFormListener(newForm);
                }, 3000);
            }
        }

        function attachFormListener(form) {
            if (!form) return;
            const buttonText = form.querySelector('button')?.textContent?.trim() || 'Subscribe';
            form.addEventListener('submit', (e) => {
                e.preventDefault();
                handleSubmit(form, buttonText);
            });
        }

        // Wire every signup form on the page (hero, footer, Reality Check, and any future form)
        document.querySelectorAll('form.signup-form').forEach((form) => attachFormListener(form));
    </script>
